# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://ccw:changeme@localhost:5432/ccw

# ── Auth.js v5 ────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=replace_with_random_base64_secret_min_32_chars

# Google OAuth — create at console.cloud.google.com
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=your_google_client_id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your_google_client_secret

# LINE Login — create at developers.line.biz
# Callback URL: http://localhost:3000/api/auth/callback/line
AUTH_LINE_ID=your_line_channel_id
AUTH_LINE_SECRET=your_line_channel_secret

# Stripe — get from dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_replace_with_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_with_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_webhook_secret

# App URL
NEXTAUTH_URL=http://localhost:3000

# Admin email — sign in ครั้งแรกก่อน แล้วรัน pnpm db:seed เพื่อ set role=admin
# ADMIN_EMAIL=your@email.com
